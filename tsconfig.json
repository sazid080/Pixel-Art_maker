{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",           // Important

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "./dist",
    "rootDir": "./src",

    "verbatimModuleSyntax": false,   // Important - turn off
    "isolatedModules": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}